# Dashboard Password (set to enable login gate)
DASHBOARD_PASSWORD=your-dashboard-password

# Redis (Upstash or any Redis REST API)
# Get these from https://upstash.com — free tier works fine
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# OR use Vercel KV naming (both work):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# AI Co-Pilot (powers alert analysis + executive summaries)
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Slack/Teams Alerts (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
