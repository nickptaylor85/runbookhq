# ═══ REQUIRED ═══
DASHBOARD_PASSWORD=your-dashboard-password
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ═══ STRIPE (required for billing) ═══
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Base plan prices (create in Stripe Dashboard → Product Catalog)
STRIPE_PRICE_TEAM=price_xxx
STRIPE_PRICE_TEAM_ANNUAL=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx
STRIPE_PRICE_BUSINESS_ANNUAL=price_xxx
STRIPE_PRICE_MSSP=price_xxx
STRIPE_PRICE_MSSP_CLIENTS=price_xxx  # £29/client/month add-on

# Add-on prices
STRIPE_PRICE_SEATS=price_xxx
STRIPE_PRICE_AI=price_xxx
STRIPE_PRICE_INTEL=price_xxx
STRIPE_PRICE_REPORTS=price_xxx
STRIPE_PRICE_API=price_xxx
STRIPE_PRICE_BRANDING=price_xxx
STRIPE_PRICE_SUPPORT=price_xxx

# ═══ AI (optional — enables AI copilot, triage, predictions) ═══
ANTHROPIC_API_KEY=sk-ant-api03-...

# ═══ EMAIL (optional — enables daily digests, notifications) ═══
RESEND_API_KEY=re_...
RESEND_FROM=alerts@yourdomain.com

# ═══ CRON (optional — secures daily cron endpoint) ═══
CRON_SECRET=your-cron-secret
