# Microsoft Defender (MDE + XDR)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Secureworks Taegis XDR
TAEGIS_CLIENT_ID=your-taegis-client-id
TAEGIS_CLIENT_SECRET=your-taegis-client-secret
TAEGIS_REGION=us  # us, eu

# Tenable.io
TENABLE_ACCESS_KEY=your-tenable-access-key
TENABLE_SECRET_KEY=your-tenable-secret-key

# Zscaler ZIA
ZIA_BASE_URL=https://zsapi.zscalerthree.net
ZIA_API_KEY=your-zia-api-key
ZIA_USERNAME=your-zia-username
ZIA_PASSWORD=your-zia-password

# Zscaler ZPA
ZPA_CLIENT_ID=your-zpa-client-id
ZPA_CLIENT_SECRET=your-zpa-client-secret
ZPA_CUSTOMER_ID=your-zpa-customer-id

# Dashboard Password (set to enable login gate)
DASHBOARD_PASSWORD=your-dashboard-password
