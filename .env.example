# Dashboard Password (set to enable login gate)
DASHBOARD_PASSWORD=your-dashboard-password

# Vercel KV (required for in-app credential storage)
# Create a KV store in Vercel Dashboard → Storage → Create KV Store → Link to Project
# These are auto-populated when you link KV to your project:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ─── OR set tool credentials directly as env vars ───
# (The dashboard will auto-detect these even without KV)

# Microsoft Defender (MDE + XDR)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Secureworks Taegis XDR
# TAEGIS_CLIENT_ID=
# TAEGIS_CLIENT_SECRET=
# TAEGIS_REGION=us

# Tenable.io
# TENABLE_ACCESS_KEY=
# TENABLE_SECRET_KEY=

# Zscaler ZIA
# ZIA_BASE_URL=
# ZIA_API_KEY=
# ZIA_USERNAME=
# ZIA_PASSWORD=

# Zscaler ZPA
# ZPA_CLIENT_ID=
# ZPA_CLIENT_SECRET=
# ZPA_CUSTOMER_ID=

# CrowdStrike Falcon
# CS_CLIENT_ID=
# CS_CLIENT_SECRET=
# CS_BASE_URL=https://api.crowdstrike.com

# SentinelOne
# S1_API_TOKEN=
# S1_BASE_URL=
