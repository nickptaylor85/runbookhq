generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role { USER ADMIN ANALYST MANAGER }
enum AccountStatus { ACTIVE SUSPENDED PENDING }
enum PlaybookStatus { DRAFT REVIEW APPROVED ACTIVE ARCHIVED EXPIRED }
enum CollabRole { OWNER EDITOR REVIEWER VIEWER }
enum ExecStatus { RUNNING PAUSED COMPLETED ABORTED }
enum ExecMode { LIVE DRILL SIMULATION }
enum NotificationType { USER_SIGNUP PLAYBOOK_SHARED PLAYBOOK_APPROVED INCIDENT_STARTED INCIDENT_COMPLETED REVIEW_REQUESTED PLAYBOOK_EXPIRING DRILL_COMPLETED COMMENT_ADDED REVIEW_DUE CERT_EXPIRING TICKET_CREATED }
enum AuditAction { PLAYBOOK_CREATED PLAYBOOK_UPDATED PLAYBOOK_DELETED PLAYBOOK_APPROVED PLAYBOOK_ARCHIVED PLAYBOOK_IMPORTED VERSION_SAVED VERSION_ROLLED_BACK EXECUTION_STARTED EXECUTION_COMPLETED EXECUTION_ABORTED USER_CREATED USER_SUSPENDED USER_DELETED SETTINGS_CHANGED COLLABORATOR_ADDED COLLABORATOR_REMOVED COMMENT_ADDED WEBHOOK_SENT TICKET_CREATED CERT_AWARDED BRANDING_UPDATED BULK_OPERATION EVIDENCE_ADDED AUTOMATION_RUN PLAYBOOK_PUBLISHED }

model User {
  id              String        @id @default(cuid())
  name            String?
  email           String        @unique
  hashedPassword  String
  role            Role          @default(USER)
  status          AccountStatus @default(ACTIVE)
  company         String?
  jobTitle        String?
  anthropicKey    String?
  apiCallsUsed    Int           @default(0)
  apiCallsLimit   Int           @default(50)
  lastLoginAt     DateTime?
  slackWebhookUrl String?
  teamsWebhookUrl String?
  locale          String        @default("en")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sessions        Session[]
  playbookData    PlaybookData?
  playbooks       Playbook[]
  versions        PlaybookVersion[]
  collaborations  Collaborator[]
  executions      Execution[]
  execActions     ExecAction[]
  notifications   Notification[]
  auditLogs       AuditLog[]    @relation("AuditActor")
  comments        Comment[]
  certifications  Certification[]
  quizAttempts    QuizAttempt[]
  timelineEntries TimelineEntry[]
  evidence        Evidence[]
  @@index([email])
  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model PlaybookData {
  id        String   @id @default(cuid())
  userId    String   @unique
  data      Json
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Playbook {
  id              String          @id @default(cuid())
  title           String
  description     String?
  severity        String          @default("medium")
  framework       String          @default("nist")
  status          PlaybookStatus  @default(DRAFT)
  data            Json
  ownerId         String
  owner           User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  versions        PlaybookVersion[]
  collaborators   Collaborator[]
  executions      Execution[]
  comments        Comment[]
  automations     AutomationDef[]
  complianceTags  String[]        @default([])
  customFields    Json?
  slaTimes        Json?
  chainedTo       String?
  reviewDueAt     DateTime?
  reviewCadence   Int?
  lastReviewedAt  DateTime?
  attachments     Json?
  published       Boolean         @default(false)
  publishedAt     DateTime?
  effectivenessScore Float?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  @@index([ownerId])
  @@index([status])
  @@index([published])
}

model PlaybookVersion {
  id          String   @id @default(cuid())
  playbookId  String
  playbook    Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  version     Int
  data        Json
  changelog   String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  @@unique([playbookId, version])
  @@index([playbookId])
}

model Collaborator {
  id          String     @id @default(cuid())
  playbookId  String
  playbook    Playbook   @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        CollabRole @default(VIEWER)
  createdAt   DateTime   @default(now())
  @@unique([playbookId, userId])
  @@index([userId])
}

model Execution {
  id          String     @id @default(cuid())
  playbookId  String
  playbook    Playbook   @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  startedById String
  startedBy   User       @relation(fields: [startedById], references: [id])
  status      ExecStatus @default(RUNNING)
  mode        ExecMode   @default(LIVE)
  incidentRef String?
  notes       String?
  score       Int?
  injects     Json?
  warRoomUrl  String?
  ticketUrl   String?
  iocs        Json?
  handoffNotes Json?
  aiAnalysis  Json?
  startedAt   DateTime   @default(now())
  completedAt DateTime?
  actions     ExecAction[]
  timeline    TimelineEntry[]
  evidence    Evidence[]
  @@index([playbookId])
  @@index([startedById])
  @@index([mode])
  @@index([status])
}

model ExecAction {
  id            String    @id @default(cuid())
  executionId   String
  execution     Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  phase         String
  actionIndex   Int
  actionText    String
  automatable   Boolean   @default(false)
  automateScript String?
  assignedTo    String?
  completed     Boolean   @default(false)
  completedById String?
  completedBy   User?     @relation(fields: [completedById], references: [id])
  completedAt   DateTime?
  notes         String?
  @@index([executionId])
}

model TimelineEntry {
  id          String   @id @default(cuid())
  executionId String
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   @default("update")
  message     String
  phase       String?
  metadata    Json?
  createdAt   DateTime @default(now())
  @@index([executionId])
}

model Evidence {
  id          String   @id @default(cuid())
  executionId String
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  phase       String?
  actionIndex Int?
  type        String
  title       String
  content     String
  metadata    Json?
  createdAt   DateTime @default(now())
  @@index([executionId])
}

model AutomationDef {
  id          String   @id @default(cuid())
  playbookId  String
  playbook    Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  phase       String
  actionIndex Int
  name        String
  method      String   @default("POST")
  endpoint    String
  headers     Json?
  body        String?
  authType    String?
  authValue   String?
  createdAt   DateTime @default(now())
  @@index([playbookId])
}

model ThreatIntel {
  id          String   @id @default(cuid())
  indicator   String
  type        String
  source      String
  score       Int?
  data        Json?
  queriedAt   DateTime @default(now())
  @@unique([indicator, source])
  @@index([indicator])
}

model Comment {
  id          String   @id @default(cuid())
  playbookId  String
  playbook    Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  phase       String?
  actionIndex Int?
  text        String
  createdAt   DateTime @default(now())
  @@index([playbookId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  @@index([userId, read])
}

model AuditLog {
  id        String      @id @default(cuid())
  actorId   String
  actor     User        @relation("AuditActor", fields: [actorId], references: [id])
  action    AuditAction
  target    String?
  details   Json?
  ip        String?
  createdAt DateTime    @default(now())
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

model Certification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playbookId  String
  drillScore  Int
  awardedAt   DateTime @default(now())
  expiresAt   DateTime
  @@index([userId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playbookId  String
  score       Int
  total       Int
  answers     Json
  createdAt   DateTime @default(now())
  @@index([userId])
}

model CustomInject {
  id          String   @id @default(cuid())
  title       String
  text        String
  severity    String   @default("medium")
  category    String?
  timingMin   Int      @default(300)
  timingMax   Int      @default(900)
  createdAt   DateTime @default(now())
}

model WebhookConfig {
  id          String   @id @default(cuid())
  name        String
  url         String
  method      String   @default("POST")
  headers     Json?
  payloadTpl  String?
  events      String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  logs        WebhookLog[]
}

model WebhookLog {
  id          String   @id @default(cuid())
  webhookId   String
  webhook     WebhookConfig @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event       String
  payload     Json
  status      Int?
  success     Boolean  @default(false)
  error       String?
  createdAt   DateTime @default(now())
  @@index([webhookId])
}

model BrandingConfig {
  id            String   @id @default(cuid())
  companyName   String?
  logoUrl       String?
  primaryColor  String   @default("4F6CF7")
  accentColor   String   @default("6366F1")
  pdfHeader     String?
  pdfFooter     String?
  updatedAt     DateTime @updatedAt
}

model CustomFieldDef {
  id          String   @id @default(cuid())
  name        String
  fieldType   String   @default("text")
  options     String[]
  required    Boolean  @default(false)
  createdAt   DateTime @default(now())
}
