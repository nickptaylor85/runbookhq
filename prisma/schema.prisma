generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══ ENUMS ═══════════════════════════════════════════════════════════════════

enum Tier {
  COMMUNITY
  TEAM
  BUSINESS
  MSSP
}

enum OrgRole {
  OWNER
  TECH_ADMIN
  ANALYST
  SALES
  VIEWER
}

enum AccountStatus {
  ACTIVE
  PENDING
  PENDING_VERIFICATION
  SUSPENDED
  DISABLED
}

enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum AlertStatus {
  NEW
  TRIAGED
  CLAIMED
  ESCALATED
  RESOLVED
  FALSE_POSITIVE
  SUPPRESSED
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  CONTAINED
  ERADICATED
  RESOLVED
  CLOSED
  POST_INCIDENT
}

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum AuditAction {
  USER_LOGIN
  USER_LOGOUT
  USER_CREATED
  USER_INVITED
  USER_SUSPENDED
  USER_DELETED
  PASSWORD_CHANGED
  MFA_ENABLED
  MFA_DISABLED
  SESSION_REVOKED
  ALERT_TRIAGED
  ALERT_CLAIMED
  ALERT_ESCALATED
  ALERT_RESOLVED
  ALERT_BULK_ACTION
  INCIDENT_CREATED
  INCIDENT_UPDATED
  INCIDENT_CLOSED
  INTEGRATION_CONNECTED
  INTEGRATION_DISCONNECTED
  INTEGRATION_SYNCED
  SETTINGS_CHANGED
  BRANDING_UPDATED
  TENANT_CREATED
  TENANT_UPDATED
  API_KEY_CREATED
  API_KEY_REVOKED
  REPORT_GENERATED
  REPORT_SHARED
  RESPONSE_ACTION_EXECUTED
}

// ═══ ORGANIZATION (Tenant Root) ══════════════════════════════════════════════
// Every row belongs to an Organization. This is the multi-tenancy boundary.

model Organization {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  tier                 Tier      @default(COMMUNITY)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  maxSeats             Int       @default(1)
  maxTools             Int       @default(3)
  maxAlerts            Int       @default(250)
  // Branding
  brandName            String?
  brandLogoUrl         String?
  brandPrimaryColor    String?   @default("#4F6CF7")
  brandAccentColor     String?   @default("#6366F1")
  brandTagline         String?
  // OT
  otEnabled            Boolean   @default(false)
  otDeviceLimit        Int       @default(0)
  // Settings
  aiEnabled            Boolean   @default(true)
  signupEnabled        Boolean   @default(true)
  anthropicKeyEncrypted String?
  // MSSP hierarchy
  parentOrgId          String?
  parentOrg            Organization?  @relation("OrgHierarchy", fields: [parentOrgId], references: [id])
  childOrgs            Organization[] @relation("OrgHierarchy")
  // Timestamps
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  // Relations
  users                User[]
  alerts               Alert[]
  incidents            Incident[]
  integrations         Integration[]
  invites              Invite[]
  auditLogs            AuditLog[]
  apiKeys              ApiKey[]
  shiftHandoffs        ShiftHandoff[]

  @@index([slug])
  @@index([parentOrgId])
  @@index([tier])
}

// ═══ USER & AUTH ═════════════════════════════════════════════════════════════

model User {
  id                 String        @id @default(cuid())
  email              String
  name               String?
  hashedPassword     String?
  role               OrgRole       @default(VIEWER)
  status             AccountStatus @default(PENDING)
  organizationId     String
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobTitle           String?
  locale             String        @default("en")
  mfaSecret          String?
  mfaEnabled         Boolean       @default(false)
  mustChangePassword Boolean       @default(false)
  lastLoginAt        DateTime?
  lastLoginIp        String?
  failedLoginCount   Int           @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  sessions           Session[]
  claimedAlerts      Alert[]       @relation("AlertClaimedBy")
  incidents          Incident[]    @relation("IncidentCommander")
  incidentTasks      IncidentTask[] @relation("TaskAssignee")
  auditLogs          AuditLog[]
  invitesSent        Invite[]

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([email])
  @@index([role])
}

model Session {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Invite {
  id             String       @id @default(cuid())
  email          String
  role           OrgRole      @default(VIEWER)
  token          String       @unique @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedById    String
  invitedBy      User         @relation(fields: [invitedById], references: [id])
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([token])
  @@index([organizationId])
}

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  hashedKey      String       @unique
  prefix         String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())

  @@index([hashedKey])
  @@index([organizationId])
}

// ═══ ALERTS ══════════════════════════════════════════════════════════════════

model Alert {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  source         String
  severity       AlertSeverity @default(MEDIUM)
  status         AlertStatus   @default(NEW)
  verdict        String?
  confidence     Int?
  triageNarrative String?
  mitreTactic    String?
  mitreTechnique String?
  mitreId        String?
  affectedAsset  String?
  affectedUser   String?
  sourceIp       String?
  destIp         String?
  claimedById    String?
  claimedBy      User?         @relation("AlertClaimedBy", fields: [claimedById], references: [id])
  incidentId     String?
  incident       Incident?     @relation(fields: [incidentId], references: [id])
  rawData        Json?
  detectedAt     DateTime      @default(now())
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, severity])
  @@index([organizationId, source])
  @@index([organizationId, createdAt])
  @@index([claimedById])
  @@index([incidentId])
}

// ═══ INCIDENTS ═══════════════════════════════════════════════════════════════

model Incident {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  severity       IncidentSeverity @default(MEDIUM)
  status         IncidentStatus   @default(OPEN)
  phase          String           @default("identification")
  commanderId    String?
  commander      User?            @relation("IncidentCommander", fields: [commanderId], references: [id])
  source         String?
  affectedAssets String[]         @default([])
  tags           String[]         @default([])
  slaDeadline    DateTime?
  slaBreached    Boolean          @default(false)
  closedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  alerts         Alert[]
  tasks          IncidentTask[]
  logs           IncidentLog[]

  @@index([organizationId, status])
  @@index([organizationId, severity])
  @@index([organizationId, createdAt])
}

model IncidentTask {
  id          String    @id @default(cuid())
  incidentId  String
  incident    Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  phase       String
  action      String
  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  status      String    @default("pending")
  priority    Int       @default(0)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([incidentId])
}

model IncidentLog {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  action     String
  actor      String
  phase      String?
  details    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([incidentId])
  @@index([createdAt])
}

// ═══ INTEGRATIONS ════════════════════════════════════════════════════════════

model Integration {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  type            String
  encryptedConfig String?
  apiUrl          String?
  enabled         Boolean      @default(false)
  status          String       @default("disconnected")
  lastSyncAt      DateTime?
  lastError       String?
  syncInterval    Int          @default(300)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ═══ AUDIT & OPS ═════════════════════════════════════════════════════════════

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorId        String?
  actor          User?        @relation(fields: [actorId], references: [id])
  action         AuditAction
  target         String?
  details        Json?
  ipAddress      String?
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, action])
  @@index([actorId])
}

model ShiftHandoff {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromAnalyst    String
  fromShift      String
  toShift        String
  activeIncidents Json?
  pendingAlerts   Json?
  notes          String
  priority       String       @default("normal")
  acknowledged   Boolean      @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}
